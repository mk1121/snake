# Build stage
FROM node:20-alpine AS build

WORKDIR /app

# Install dependencies
COPY package*.json ./
RUN npm install

# Copy source and build for web
COPY . .
RUN npx expo export --platform web

# Production stage
FROM nginx:stable-alpine

# Copy the build output to nginx
COPY --from=build /app/dist /usr/share/nginx/html

# Add custom nginx config to handle SPA routing if needed
RUN printf 'server {\n    listen 80;\n    location / {\n        root /usr/share/nginx/html;\n        index index.html;\n        try_files $uri $uri/ /index.html;\n    }\n}' > /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
